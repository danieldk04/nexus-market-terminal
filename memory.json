    "news_summary": [
        {
            "theme": "Sectorselectiviteit en volatiliteit",
            "summary": "De markt vertoont een tweedeling met sterke techndelen (AEX +1%, doorbraak 1000 punten) versus zwakke defensieve aandelen (Unilever, Ferrari, Novo Nordisk). Voor beleggers in brede ETFs betekent dit dat winsten in tech-heavy indices kunnen worden gedempt door onderperformance in consumer- en farmacasectoren, wat vraagt om attentie voor positie-weging."
        },
        {
            "theme": "Geopolitieke risico's drukken markten",
            "summary": "Oorlogen (Iran-Israel) en geopolitieke spanningen veroorzaken onrust en zorgen voor divergentie tussen markten: Europese aandelen herstellen terwijl Aziatische aandelen dalen. Dit cre\u00ebert wisselende rendementen in wereldwijde portefeuilles en onderstreept dat geografische diversificatie niet altijd beschermt tegen gelijktijdige schokken."
        },
        {
            "theme": "M&A-activiteit be\u00efnvloedt koersen",
            "summary": "Prosus haalt Just Eat Takeaway van de beurs (positief voor koers) en Air France-KLM lijdt onder geopolitieke impact. Deze transacties en operationele schokken be\u00efnvloeden individuele aandelen aanzienlijk, terwijl breed ge\u00efndexeerde beleggers via ETFs minder direct worden geraakt maar wel blootgesteld aan herbalanceringseffecten."
        },
        {
            "theme": "Insiderkoopjes signaleren bodemvorming",
            "summary": "CEO en CFO van Brunel kopen aandelen in na een dip, wat doorgaans een bullish signaal is van management-vertrouwen. Dit type insider-activiteit contrasteert met brede marktvolatiliteit en kan voor actieve beleggers en ETF-beleggers een indicatie zijn dat bepaalde sectoren misschien oververkocht zijn en herstel aankondigen."
        }
    ],
